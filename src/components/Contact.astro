---
---
interface Props {
    email?: string
    githubUrl?: string
    linkedinUrl?: string
    }

const {
    email = "votre@email.com",
    githubUrl = "https://github.com/votre-username",
    linkedinUrl = "https://linkedin.com/in/votre-profil",
    } = Astro.props
---

<section class="section" id="contact">
    <div class="left">
        <p class="section-label">Contact</p>
        <h2 class="contact-title">Travaillons <em>ensemble.</em></h2>
        <p class="contact-desc">
            Disponible pour des missions freelance, des collaborations ou
            simplement pour échanger autour d'un projet.
        </p>
        <div class="contact-links">
            <a class="contact-link" href={`mailto:${email}`}>
                <div class="link-icon">@</div>
                <div class="link-label">
                    <div>Email</div>
                    <div class="link-sub">{email}</div>
                </div>
                <span class="link-arrow">↗</span>
            </a>
            <a class="contact-link" href={githubUrl} target="_blank" rel="noopener">
                <div class="link-icon">gh</div>
                <div class="link-label">
                    <div>GitHub</div>
                    <div class="link-sub">{githubUrl.replace("https://", "")}</div>
                </div>
                <span class="link-arrow">↗</span>
            </a>
            <a class="contact-link" href={linkedinUrl} target="_blank" rel="noopener">
                <div class="link-icon">in</div>
                <div class="link-label">
                    <div>LinkedIn</div>
                    <div class="link-sub">{linkedinUrl.replace("https://", "")}</div>
                </div>
                <span class="link-arrow">↗</span>
            </a>
        </div>
    </div>

    <form class="form" name="contact" method="POST" data-netlify="true">
        <div class="field">
            <label for="name">Nom</label>
            <input id="name" name="name" type="text" placeholder="Jean Dupont" required />
        </div>
        <div class="field">
            <label for="email">Email</label>
            <input id="email" name="email" type="email" placeholder="jean@exemple.com" required />
        </div>
        <div class="field">
            <label for="message">Message</label>
            <textarea id="message" name="message" rows="5" placeholder="Bonjour, j'aimerais discuter de..." required></textarea>
        </div>
        <button type="submit" class="send-btn">Envoyer le message</button>
    </form>
</section>

<style>
    @import url('https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Mono:wght@400;500&display=swap');

    .section {
        padding: 4rem 0;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        align-items: start;
    }

    @media (max-width: 680px) {
        .section {
            grid-template-columns: 1fr;
            gap: 2.5rem;
        }
    }

    .section-label {
        font-family: 'DM Mono', monospace;
        font-size: 0.75rem;
        color: #888;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 1.5rem;
    }

    .section-label::before {
        content: '';
        width: 20px;
        height: 1px;
        background: currentColor;
        display: inline-block;
    }

    .contact-title {
        font-family: 'DM Serif Display', serif;
        font-size: 2rem;
        font-weight: 400;
        color: #111;
        line-height: 1.15;
        margin: 0 0 1rem;
    }

    .contact-title em {
        font-style: italic;
        color: #666;
    }

    .contact-desc {
        font-size: 0.875rem;
        color: #666;
        line-height: 1.7;
        margin-bottom: 2rem;
    }

    .contact-links {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .contact-link {
        display: flex;
        align-items: center;
        gap: 12px;
        font-size: 0.8125rem;
        color: #111;
        text-decoration: none;
        padding: 12px 14px;
        border: 1px solid #eee;
        border-radius: 8px;
        transition: background 0.15s;
    }

    .contact-link:hover {
        background: #fafafa;
    }

    .link-icon {
        width: 32px;
        height: 32px;
        border-radius: 6px;
        background: #f5f5f5;
        border: 1px solid #eee;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'DM Mono', monospace;
        font-size: 0.625rem;
        color: #888;
        flex-shrink: 0;
    }

    .link-label {
        flex: 1;
    }

    .link-sub {
        font-size: 0.6875rem;
        color: #aaa;
        font-family: 'DM Mono', monospace;
        margin-top: 2px;
    }

    .link-arrow {
        font-size: 0.875rem;
        color: #aaa;
    }

    .form {
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

    .field {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .field label {
        font-size: 0.75rem;
        font-weight: 500;
        color: #555;
    }

    .field input,
    .field textarea {
        font-size: 0.8125rem;
        padding: 10px 14px;
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        background: #fff;
        color: #111;
        outline: none;
        transition: border-color 0.15s;
        resize: none;
        font-family: inherit;
    }

    .field input:focus,
    .field textarea:focus {
        border-color: #aaa;
    }

    .send-btn {
        margin-top: 4px;
        padding: 11px 24px;
        background: #111;
        color: #fff;
        font-size: 0.8125rem;
        font-weight: 500;
        border: none;
        border-radius: 999px;
        cursor: pointer;
        transition: opacity 0.15s;
        align-self: flex-start;
        font-family: inherit;
    }

    .send-btn:hover {
        opacity: 0.8;
    }
</style>
---
