---
interface Project {
    num: string
    title: string
    description: string
    stack: string[]
    url?: string
}

interface Props {
    projects?: Project[]
}

const { projects = [
    {
        num: "01",
        title: "Dashboard analytique",
        description: "Interface de visualisation de données en temps réel pour une startup SaaS. Charts interactifs, filtres avancés, export CSV.",
        stack: ["Next.js", "Recharts", "Prisma"],
        url: "#",
    },
    {
        num: "02",
        title: "API de paiement",
        description: "Microservice de traitement des paiements avec Stripe. Webhooks, idempotence, logging structuré, 99.9% uptime.",
        stack: ["Node.js", "Stripe", "PostgreSQL"],
        url: "#",
    },
    {
        num: "03",
        title: "App mobile fitness",
        description: "Suivi d'entraînements avec synchronisation hors ligne. Animations fluides, notifications push, intégration HealthKit.",
        stack: ["React Native", "Expo", "SQLite"],
        url: "#",
    },
] } = Astro.props
---

<section class="section" id="projets">
    <p class="section-label">Projets</p>
    <div class="grid">
        {projects.map((project) => (
                <a href={project.url ?? "#"} class="card">
                    <span class="card-num">{project.num}</span>
                    <h3 class="card-title">{project.title}</h3>
                    <p class="card-desc">{project.description}</p>
                    <div class="card-footer">
                        <div class="card-stack">
                            {project.stack.map((tech) => (
                                    <span class="pill">{tech}</span>
                            ))}
                        </div>
                        <span class="arrow">↗</span>
                    </div>
                </a>
        ))}
    </div>
</section>

<style>
    @import url('https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Mono:wght@400;500&display=swap');

    .section {
        padding: 4rem 0;
    }

    .section-label {
        font-family: 'DM Mono', monospace;
        font-size: 0.75rem;
        color: #888;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 2rem;
    }

    .section-label::before {
        content: '';
        width: 20px;
        height: 1px;
        background: currentColor;
        display: inline-block;
    }

    .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1px;
        border: 1px solid #eee;
        border-radius: 12px;
        overflow: hidden;
        background: #eee;
    }

    .card {
        background: #fff;
        padding: 1.75rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
        text-decoration: none;
        transition: background 0.15s;
    }

    .card:hover {
        background: #fafafa;
    }

    .card-num {
        font-family: 'DM Mono', monospace;
        font-size: 0.6875rem;
        color: #aaa;
    }

    .card-title {
        font-family: 'DM Serif Display', serif;
        font-size: 1.3rem;
        font-weight: 400;
        color: #111;
        line-height: 1.2;
        margin: 0;
    }

    .card-desc {
        font-size: 0.8125rem;
        color: #666;
        line-height: 1.65;
        flex: 1;
        margin: 0;
    }

    .card-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-top: 1rem;
        border-top: 1px solid #eee;
    }

    .card-stack {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
    }

    .pill {
        font-family: 'DM Mono', monospace;
        font-size: 0.625rem;
        color: #888;
        background: #f5f5f5;
        border: 1px solid #e8e8e8;
        padding: 3px 8px;
        border-radius: 3px;
    }

    .arrow {
        font-size: 1rem;
        color: #aaa;
        transition: transform 0.15s;
    }

    .card:hover .arrow {
        transform: translate(2px, -2px);
    }
</style>