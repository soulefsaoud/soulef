---
import Hero from '../components/Hero.astro'
import ProjectCards from '../components/ProjectCards.astro'
import Stack from '../components/Stack.astro'
import Contact from '../components/Contact.astro'
---

<!doctype html>
<html lang="fr">
<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<meta name="description" content="Portfolio de Votre Nom — Développeur fullstack" />
	<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
	<title>Soulef SAOUD — Développeur fullstack</title>
	<link
		rel="preconnect"
		href="https://fonts.googleapis.com"
	/>
	<link
		rel="preconnect"
		href="https://fonts.gstatic.com"
		crossorigin
	/>
	<link
		href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Mono:wght@400;500&display=swap"
		rel="stylesheet"
	/>
</head>
<body>

<!-- Navigation -->
<header class="header">
	<nav class="nav">
		<a href="/" class="nav-logo">VN</a>
		<div class="nav-links">
			<a href="#projets" class="nav-link">Projets</a>
			<a href="#stack" class="nav-link">Stack</a>
			<a href="#contact" class="nav-link">Contact</a>
			<a
				href="https://github.com/soulefsaoud"
				target="_blank"
				rel="noopener"
				class="nav-cta"
			>GitHub ↗</a>
		</div>
	</nav>
</header>

<!-- Contenu principal -->
<main class="main">

	<Hero
		name="Soulef"
		title="Développeur fullstack"
		description="Je conçois et développe des interfaces web soignées, rapides et accessibles. Passionné par la qualité du code et l'expérience utilisateur."
		available={true}
		stack={["TypeScript", "React", "Astro", "Node.js", "PostgreSQL", "Docker"]}
		githubUrl="https://github.com/soulefsaoud"
		linkedinUrl="linkedin.com/in/soulef-saoud-646205122"
	/>

	<ProjectCards
		projects={[
			{
				num: "01",
				title: "Dashboard analytique",
				description: "Interface de visualisation de données en temps réel pour une startup SaaS. Charts interactifs, filtres avancés, export CSV.",
				stack: ["Next.js", "Recharts", "Prisma"],
				url: "#",
			},
			{
				num: "02",
				title: "API de paiement",
				description: "Microservice de traitement des paiements avec Stripe. Webhooks, idempotence, logging structuré, 99.9% uptime.",
				stack: ["Node.js", "Stripe", "PostgreSQL"],
				url: "#",
			},
			{
				num: "03",
				title: "App mobile fitness",
				description: "Suivi d'entraînements avec synchronisation hors ligne. Animations fluides, notifications push, intégration HealthKit.",
				stack: ["React Native", "Expo", "SQLite"],
				url: "#",
			},
		]}
	/>

	<Stack
		categories={[
			{
				label: "Langages",
				items: [
					{ name: "TypeScript", color: "#3178c6" },
					{ name: "JavaScript", color: "#f7df1e" },
					{ name: "Python",     color: "#3572a5" },
					{ name: "Java",       color: "#b07219" },
				],
			},
			{
				label: "Frontend",
				items: [
					{ name: "React" },
					{ name: "Astro" },
					{ name: "Next.js" },
					{ name: "Tailwind" },
				],
			},
			{
				label: "Backend",
				items: [
					{ name: "Node.js" },
					{ name: "Express" },
					{ name: "Fastify" },
					{ name: "PostgreSQL" },
					{ name: "Redis" },
				],
			},
			{
				label: "DevOps",
				items: [
					{ name: "Docker" },
					{ name: "GitHub Actions" },
					{ name: "Vercel" },
					{ name: "AWS" },
				],
			},
		]}
	/>

	<Contact
		email="soulef.saoud@laposte.net"
		githubUrl="https://github.com/soulefsaoud"
		linkedinUrl="linkedin.com/in/soulef-saoud-646205122"
	/>

</main>

<!-- Footer -->
<footer class="footer">
	<span>© {new Date().getFullYear()} Votre Nom</span>
	<span>Fait avec Astro &amp; ☕</span>
</footer>

</body>
</html>

<style is:global>
	*, *::before, *::after {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	html {
		scroll-behavior: smooth;
	}

	body {
		font-family: 'DM Mono', 'Courier New', monospace;
		background: #fafafa;
		color: #111;
		-webkit-font-smoothing: antialiased;
	}

	/* Supprimer les imports Google Fonts dans les composants
       car on les charge ici une seule fois */
</style>

<style>
	.header {
		position: sticky;
		top: 0;
		z-index: 100;
		background: rgba(250, 250, 250, 0.85);
		backdrop-filter: blur(8px);
		-webkit-backdrop-filter: blur(8px);
		border-bottom: 1px solid #eee;
	}

	.nav {
		max-width: 900px;
		margin: 0 auto;
		padding: 0 2rem;
		height: 56px;
		display: flex;
		align-items: center;
		justify-content: space-between;
	}

	.nav-logo {
		font-family: 'DM Mono', monospace;
		font-size: 0.8125rem;
		font-weight: 500;
		color: #111;
		text-decoration: none;
		border: 1px solid #eee;
		padding: 5px 10px;
		border-radius: 6px;
		transition: background 0.15s;
	}

	.nav-logo:hover {
		background: #f0f0f0;
	}

	.nav-links {
		display: flex;
		align-items: center;
		gap: 2rem;
	}

	.nav-link {
		font-family: 'DM Mono', monospace;
		font-size: 0.75rem;
		color: #888;
		text-decoration: none;
		transition: color 0.15s;
	}

	.nav-link:hover {
		color: #111;
	}

	.nav-cta {
		font-family: 'DM Mono', monospace;
		font-size: 0.75rem;
		color: #111;
		text-decoration: none;
		border: 1px solid #e0e0e0;
		padding: 6px 14px;
		border-radius: 999px;
		transition: background 0.15s;
	}

	.nav-cta:hover {
		background: #f0f0f0;
	}

	.main {
		max-width: 900px;
		margin: 0 auto;
		padding: 0 2rem;
	}

	.footer {
		max-width: 900px;
		margin: 0 auto;
		padding: 2rem;
		border-top: 1px solid #eee;
		display: flex;
		justify-content: space-between;
		align-items: center;
		font-family: 'DM Mono', monospace;
		font-size: 0.6875rem;
		color: #aaa;
		margin-top: 4rem;
	}

	@media (max-width: 600px) {
		.nav-links {
			gap: 1rem;
		}
		.nav-link {
			display: none;
		}
		.footer {
			flex-direction: column;
			gap: 8px;
			text-align: center;
		}
	}
</style>